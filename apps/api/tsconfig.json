{
  "extends": "../../tsconfig.base.json",
  "compilerOptions": {
    // "bundler" resolution (not NodeNext) so @watchy/types can use extension-less
    // relative imports — Metro consumes the same sources and can't resolve ".js" → ".ts".
    // API sources keep explicit ".js" extensions so the tsc-emitted output stays Node-safe.
    "module": "esnext",
    "moduleResolution": "bundler",
    "outDir": "dist",
    "rootDir": "src",
    "noEmit": false,
    "types": ["node"]
  },
  "include": ["src/**/*.ts"]
}

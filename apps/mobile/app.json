{
  "expo": {
    "name": "watchy",
    "slug": "watchy",
    "version": "1.1.0",
    "orientation": "portrait",
    "icon": "./assets/images/icon.png",
    "scheme": "watchy",
    "userInterfaceStyle": "dark",
    "ios": {
      "bundleIdentifier": "com.watchy-app.watchy",
      "buildNumber": "1",
      "supportsTablet": false,
      "infoPlist": {
        "ITSAppUsesNonExemptEncryption": false,
        "CFBundleAllowMixedLocalizations": true,
        "CFBundleDevelopmentRegion": "fr"
      }
    },
    "locales": {
      "fr": "./languages/fr.json",
      "en": "./languages/en.json"
    },
    "android": {
      "package": "com.watchyapp.watchy",
      "adaptiveIcon": {
        "backgroundColor": "#eef1f5",
        "foregroundImage": "./assets/images/watchy-icon.png"
      },
      "predictiveBackGestureEnabled": false,
      "permissions": [
        "android.permission.RECORD_AUDIO",
        "android.permission.CAMERA"
      ]
    },
    "web": {
      "output": "static",
      "favicon": "./assets/images/favicon.png"
    },
    "plugins": [
      "expo-router",
      [
        "expo-image-picker",
        {
          "photosPermission": "Watchy utilise vos photos pour ajouter des montres à votre collection.",
          "cameraPermission": "Watchy utilise la caméra pour photographier vos montres."
        }
      ],
      [
        "expo-camera",
        {
          "cameraPermission": "Watchy utilise la caméra pour photographier vos montres."
        }
      ],
      [
        "expo-splash-screen",
        {
          "backgroundColor": "#eef1f5",
          "android": {
            "image": "./assets/images/watchy-icon.png",
            "imageWidth": 96
          }
        }
      ],
      "expo-secure-store",
      "@react-native-community/datetimepicker",
      "expo-apple-authentication",
      "expo-localization"
    ],
    "experiments": {
      "typedRoutes": true,
      "reactCompiler": true
    },
    "extra": {
      "router": {},
      "eas": {
        "projectId": "8e57eb43-0cb5-4a46-9273-16fa63105ac3"
      }
    },
    "owner": "debouttom"
  }
}
